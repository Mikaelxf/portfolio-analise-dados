  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "calculo-relacao",
   "metadata": {},
   "outputs": [],
   "source": [
    "df['relacao_faturamento_lucro'] = df['faturamento_anual'] / df['lucro_anual']\n",
