  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "converter-tipos",
   "metadata": {},
   "outputs": [],
   "source": [
    "colunas_inteiras = ['quantidade_funcionarios', 'faturamento_anual', 'lucro_anual']\n",
    "\n",
    "df[colunas_inteiras] = df[colunas_inteiras].astype(int)\n",
    "df['avaliacao_funcionarios'] = df['avaliacao_funcionarios'].astype(float)\n",
    "\n",
    "df.dtypes"
   ]
